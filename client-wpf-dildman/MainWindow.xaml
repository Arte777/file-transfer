<Window x:Class="FileTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NON PRO v7.0.2"
        Height="500" Width="720"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ═══ Accent Colors ═══ -->
        <SolidColorBrush x:Key="Accent" Color="#00CEC9"/>
        <SolidColorBrush x:Key="AccentLight" Color="#81ECEC"/>
        <SolidColorBrush x:Key="AccentDark" Color="#00A19B"/>
        <SolidColorBrush x:Key="Danger" Color="#FF4757"/>
        <SolidColorBrush x:Key="Success" Color="#2ED573"/>
        <SolidColorBrush x:Key="Warn" Color="#FFA502"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F1F2F6"/>
        <SolidColorBrush x:Key="TextDim" Color="#57606F"/>
        <SolidColorBrush x:Key="Surface" Color="#0D0E12"/>
        <SolidColorBrush x:Key="SurfaceLight" Color="#141620"/>

        <!-- ═══ Title Bar Button ═══ -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#57606F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1E28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Close Button (Red Hover) ═══ -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF4757"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Modern TextBox ═══ -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#0A0B0F"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="CaretBrush" Value="#00CEC9"/>
            <Setter Property="SelectionBrush" Value="#00CEC9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1C1E28"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00CEC9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Primary Action Button ═══ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="12" Padding="0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00CEC9" Offset="0"/>
                                    <GradientStop Color="#81ECEC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#00CEC9" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00CEC9" BlurRadius="32" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1C1E28"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Opacity="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#57606F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Telegram Button ═══ -->
        <Style x:Key="TelegramBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="12" Padding="0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#229ED9"/>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2CB3F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Progress Bar Style ═══ -->
        <Style x:Key="NeonProgress" TargetType="ProgressBar">
            <Setter Property="Background" Value="#0A0B0F"/>
            <Setter Property="Foreground" Value="#00CEC9"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="2" Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00CEC9" Offset="0"/>
                                            <GradientStop Color="#81ECEC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ OUTER SHELL ═══ -->
    <Border x:Name="WindowBorder" CornerRadius="16" ClipToBounds="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            BorderThickness="1" BorderBrush="#1A1C26">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0E12" Offset="0"/>
                <GradientStop Color="#111320" Offset="0.5"/>
                <GradientStop Color="#0D0E12" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" BorderBrush="#1A1C26" BorderThickness="0,0,0,1">
                <Border.Background>
                    <SolidColorBrush Color="#0B0C10"/>
                </Border.Background>
                <Grid Margin="16,0">
                    <!-- Left: Logo -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00CEC9" Offset="0"/>
                                    <GradientStop Color="#81ECEC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔥" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="NON PRO" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                   Foreground="#F1F2F6" VerticalAlignment="Center"/>
                        <TextBlock Text=" v7.0.2" FontFamily="Segoe UI" FontSize="13"
                                   Foreground="#57606F" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-4,0">
                        <Button Content="—" Style="{StaticResource TitleBtn}" Click="MinimizeWindow_Click"/>
                        <Button Content="✕" Style="{StaticResource CloseBtn}" Click="CloseWindow_Click" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>  <!-- Left panel -->
                    <ColumnDefinition Width="*"/>    <!-- Right panel -->
                </Grid.ColumnDefinitions>

                <!-- ════ LEFT PANEL — Avatar & Input ════ -->
                <Border Grid.Column="0" BorderBrush="#1A1C26" BorderThickness="0,0,1,0">
                    <Grid Margin="24,28,24,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Avatar -->
                            <RowDefinition Height="Auto"/>  <!-- Username label -->
                            <RowDefinition Height="Auto"/>  <!-- Username input -->
                            <RowDefinition Height="Auto"/>  <!-- Hack Button -->
                            <RowDefinition Height="Auto"/>  <!-- Telegram Button -->
                            <RowDefinition Height="*"/>     <!-- Spacer -->
                            <RowDefinition Height="Auto"/>  <!-- Version info -->
                        </Grid.RowDefinitions>

                        <!-- Avatar -->
                        <Grid Grid.Row="0" Width="120" Height="120" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <!-- Outer ring glow -->
                            <Ellipse Width="120" Height="120" StrokeThickness="2" Opacity="0.25">
                                <Ellipse.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00CEC9" Offset="0"/>
                                        <GradientStop Color="#81ECEC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00CEC9" BlurRadius="24" ShadowDepth="0" Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <!-- Dark fill -->
                            <Ellipse Width="110" Height="110" Fill="#0A0B0F"/>
                            <!-- Placeholder text -->
                            <TextBlock x:Name="TxtPlaceholder" Text="?" 
                                       Foreground="#00CEC9" FontSize="40" FontFamily="Segoe UI Black"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3"/>
                            <!-- Avatar image -->
                    <Ellipse x:Name="AvatarCircle" Width="106" Height="106" StrokeThickness="2.5" VerticalAlignment="Top" Margin="0,7,0,0">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C5CE7" Offset="0"/>
                                <GradientStop Color="#A29BFE" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.Fill>
                            <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                        </Grid>

                        <!-- Label -->
                        <TextBlock Grid.Row="1" Text="ROBLOX НИКНЕЙМ" FontFamily="Segoe UI" FontWeight="Bold"
                                   FontSize="10" Foreground="#57606F" Margin="4,0,0,6"/>

                        <!-- Username Input -->
                        <TextBox x:Name="TxtUsername" Grid.Row="2" Style="{StaticResource ModernInput}"
                                 Height="42" Margin="0,0,0,14"
                                 TextChanged="TxtUsername_TextChanged"
                                 GotFocus="TxtUsername_GotFocus"
                                 LostFocus="TxtUsername_LostFocus"/>

                        <!-- Hack Button -->
                        <Button x:Name="BtnHack" Grid.Row="3" Content="⚡ ВЗЛОМАТЬ" IsEnabled="False"
                                Style="{StaticResource PrimaryBtn}" Height="46" Click="BtnHack_Click"/>

                        <!-- Telegram Button -->
                        <Button x:Name="BtnTelegram" Grid.Row="4" Content="📢 НАШ TELEGRAM"
                                Style="{StaticResource TelegramBtn}" Height="42" Margin="0,10,0,0" Click="BtnTelegram_Click"/>

                        <!-- Version tag -->
                        <TextBlock Grid.Row="6" Text="build 7.0.2 • NON PRO" 
                                   FontFamily="Segoe UI" FontSize="10" Foreground="#2A2D3A"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    </Grid>
                </Border>

                <!-- ════ RIGHT PANEL — Console & Status ════ -->
                <Grid Grid.Column="1" Margin="20,20,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Status badge -->
                        <RowDefinition Height="*"/>      <!-- Console log -->
                        <RowDefinition Height="Auto"/>   <!-- Progress bar -->
                        <RowDefinition Height="Auto"/>   <!-- Password result -->
                    </Grid.RowDefinitions>

                    <!-- Status badge -->
                    <Border Grid.Row="0" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                            HorizontalAlignment="Left">
                        <Border.Background>
                            <SolidColorBrush x:Name="StatusBadgeBg" Color="#0F1014"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#2ED573" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TbStatusLabel" Text="СИСТЕМА ГОТОВА" 
                                       FontFamily="Segoe UI" FontWeight="Bold" FontSize="10"
                                       Foreground="#57606F" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Console log area -->
                    <Border Grid.Row="1" CornerRadius="12" Margin="0,0,0,12"
                            BorderThickness="1" BorderBrush="#1A1C26">
                        <Border.Background>
                            <SolidColorBrush Color="#08090C"/>
                        </Border.Background>
                        <Grid>
                            <!-- Console header -->
                            <Border CornerRadius="12,12,0,0" Padding="12,8" VerticalAlignment="Top"
                                    BorderThickness="0,0,0,1" BorderBrush="#1A1C26">
                                <Border.Background>
                                    <SolidColorBrush Color="#0C0D11"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#FF4757" Margin="0,0,6,0"/>
                                    <Ellipse Width="8" Height="8" Fill="#FFA502" Margin="0,0,6,0"/>
                                    <Ellipse Width="8" Height="8" Fill="#2ED573" Margin="0,0,10,0"/>
                                    <TextBlock Text="terminal" FontFamily="Consolas" FontSize="10" Foreground="#2A2D3A"/>
                                </StackPanel>
                            </Border>
                            <!-- Console content -->
                            <ScrollViewer x:Name="ConsoleScroller" Margin="0,32,0,0" 
                                          VerticalScrollBarVisibility="Auto" Padding="14,8,14,10">
                                <TextBlock x:Name="TbConsole" 
                                       FontFamily="Consolas" FontSize="11" Foreground="#6C5CE7"
                                       TextWrapping="Wrap" LineHeight="16">
                                <Run Foreground="#2A2D3A">[system]</Run><Run Text=" Core loaded successfully."/><LineBreak/>
                                <Run Foreground="#2A2D3A">[system]</Run><Run Text=" Awaiting user input..."/>
                            </TextBlock>        <LineBreak/>
                                    <Run Foreground="#2A2D3A">[ready]</Run>
                                    <Run Foreground="#2ED573"> Ожидание ввода никнейма...</Run>
                                </TextBlock>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Progress bar -->
                    <ProgressBar x:Name="HackProgress" Grid.Row="2" Style="{StaticResource NeonProgress}"
                                 Value="0" Maximum="100" Margin="0,0,0,8" Visibility="Collapsed"/>

                    <!-- Password Result -->
                    <Border x:Name="PanelResult" Grid.Row="3" Visibility="Collapsed"
                            CornerRadius="12" Padding="16,12" BorderThickness="1"
                            BorderBrush="#143D1F">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0A1210" Offset="0"/>
                                <GradientStop Color="#0D150E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔓" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="ПАРОЛЬ НАЙДЕН" FontFamily="Segoe UI" FontWeight="ExtraBold" 
                                           FontSize="9" Foreground="#2ED573" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtPassword" Text="—" Background="Transparent"
                                         Foreground="#2ED573" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                         IsReadOnly="True" Focusable="True" CaretBrush="#2ED573"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
