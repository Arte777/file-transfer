<Window x:Class="FileTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RAH NonPro v7.0.2"
        Height="540" Width="850"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ═══ Accent Colors ═══ -->
        <SolidColorBrush x:Key="Accent" Color="#6C5CE7"/>
        <SolidColorBrush x:Key="AccentLight" Color="#A29BFE"/>
        <SolidColorBrush x:Key="AccentDark" Color="#4A3FC4"/>
        <SolidColorBrush x:Key="Danger" Color="#FF4757"/>
        <SolidColorBrush x:Key="Success" Color="#2ED573"/>
        <SolidColorBrush x:Key="Warn" Color="#FFA502"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F1F2F6"/>
        <SolidColorBrush x:Key="TextDim" Color="#57606F"/>
        <SolidColorBrush x:Key="Surface" Color="#0D0E12"/>
        <SolidColorBrush x:Key="SurfaceLight" Color="#141620"/>

        <!-- ═══ Title Bar Button ═══ -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#57606F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C1E28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Close Button (Red Hover) ═══ -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF4757"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Modern TextBox ═══ -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#0A0B0F"/>
            <Setter Property="Foreground" Value="#F1F2F6"/>
            <Setter Property="CaretBrush" Value="#6C5CE7"/>
            <Setter Property="SelectionBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1C1E28"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C5CE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Primary Action Button ═══ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="12" Padding="0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6C5CE7" Offset="0"/>
                                    <GradientStop Color="#A29BFE" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#6C5CE7" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6C5CE7" BlurRadius="32" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1C1E28"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Opacity="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#57606F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Telegram Button ═══ -->
        <Style x:Key="TelegramBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="12" Padding="0,12">
                            <Border.Background>
                                <SolidColorBrush Color="#229ED9"/>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2CB3F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Progress Bar Style ═══ -->
        <Style x:Key="NeonProgress" TargetType="ProgressBar">
            <Setter Property="Background" Value="#0A0B0F"/>
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="2" Background="{TemplateBinding Background}" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6C5CE7" Offset="0"/>
                                            <GradientStop Color="#A29BFE" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══ OUTER SHELL ═══ -->
    <Border x:Name="WindowBorder" CornerRadius="16" ClipToBounds="True"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            BorderThickness="1" BorderBrush="#1A1C26">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0E12" Offset="0"/>
                <GradientStop Color="#111320" Offset="0.5"/>
                <GradientStop Color="#0D0E12" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="50" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" BorderBrush="#1A1C26" BorderThickness="0,0,0,1">
                <Border.Background>
                    <SolidColorBrush Color="#0B0C10"/>
                </Border.Background>
                <Grid Margin="16,0">
                    <!-- Left: Logo -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6C5CE7" Offset="0"/>
                                    <GradientStop Color="#A29BFE" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⚡" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="AppTitleMain" Text="RAH NonPro" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                   Foreground="#F1F2F6" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AppTitleVersion" Text=" v7.0.2" FontFamily="Segoe UI" FontSize="13"
                                   Foreground="#57606F" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right: Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-4,0">
                        <Button Content="—" Style="{StaticResource TitleBtn}" Click="MinimizeWindow_Click"/>
                        <Button Content="✕" Style="{StaticResource CloseBtn}" Click="CloseWindow_Click" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/> <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>   <!-- Main area -->
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#0A0B0F" BorderBrush="#1A1C26" BorderThickness="0,0,1,0" CornerRadius="0,0,0,16">
                    <StackPanel Margin="0,20,0,0">
                        <Button x:Name="BtnNavDashboard" Content="ГЛАВНАЯ" Style="{StaticResource PrimaryBtn}" Margin="16,0,16,10" Height="40" Background="Transparent" Foreground="White" Click="BtnNavDashboard_Click"/>
                        <Button x:Name="BtnNavSettings" Content="НАСТРОЙКИ" Style="{StaticResource PrimaryBtn}" Margin="16,0,16,10" Height="40" Background="Transparent" Foreground="#57606F" Click="BtnNavSettings_Click"/>
                        <Button x:Name="BtnNavLogs" Content="ЛОГИ" Style="{StaticResource PrimaryBtn}" Margin="16,0,16,10" Height="40" Background="Transparent" Foreground="#57606F" Click="BtnNavLogs_Click"/>
                    </StackPanel>
                </Border>

                <!-- CONTENT AREA -->
                <Grid Grid.Column="1" Margin="24">
                    
                    <!-- VIEW: DASHBOARD -->
                    <Grid x:Name="ViewDashboard" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- LEFT COL: Avatar, Input, Buttons -->
                        <StackPanel Grid.Column="0" Grid.RowSpan="3" VerticalAlignment="Top">
                            <!-- 1. AVATAR BLOCK -->
                            <Grid x:Name="BlockAvatar" Width="120" Height="140" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <!-- Outer ring glow -->
                    <Ellipse Width="120" Height="120" StrokeThickness="2" Opacity="0.25" VerticalAlignment="Top">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
                                <GradientStop Color="{DynamicResource AccentLight}" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.Effect>
                            <DropShadowEffect Color="{DynamicResource Accent}" BlurRadius="24" ShadowDepth="0" Opacity="0.4"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <!-- Dark fill -->
                    <Ellipse Width="110" Height="110" Fill="#0A0B0F" VerticalAlignment="Top"/>
                    <!-- Placeholder text -->
                    <TextBlock x:Name="TxtPlaceholder" Text="?" 
                               Foreground="{DynamicResource Accent}" FontSize="40" FontFamily="Segoe UI Black"
                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,25,0,0" Opacity="0.3"/>
                    <!-- Avatar image -->
                    <Ellipse x:Name="AvatarCircle" Width="106" Height="106" StrokeThickness="2.5" VerticalAlignment="Top" Margin="0,7,0,0">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource Accent}" Offset="0"/>
                                <GradientStop Color="{DynamicResource AccentLight}" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.Fill>
                            <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                                <TextBlock Text="ROBLOX НИКНЕЙМ" FontFamily="Segoe UI" FontWeight="Bold"
                                           FontSize="10" Foreground="#57606F" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                            </Grid>

                            <!-- 2. INPUT FIELD -->
                            <TextBox x:Name="TxtUsername" Width="232" Height="42" Margin="0,0,0,16"
                                     Style="{StaticResource ModernInput}"
                                     TextChanged="TxtUsername_TextChanged"
                                     GotFocus="TxtUsername_GotFocus"
                                     LostFocus="TxtUsername_LostFocus"/>

                            <!-- 3. HACK BUTTON -->
                            <Button x:Name="BtnHack" Width="232" Height="46" Margin="0,0,0,16"
                                    Content="⚡ ВЗЛОМАТЬ" IsEnabled="False"
                                    Style="{StaticResource PrimaryBtn}" Click="BtnHack_Click"/>

                            <!-- 4. TELEGRAM BUTTON -->
                            <Button x:Name="BtnTelegram" Width="232" Height="42"
                                    Content="📢 НАШ TELEGRAM"
                                    Style="{StaticResource TelegramBtn}" Click="BtnTelegram_Click"/>
                        </StackPanel>

                        <!-- RIGHT COL: Console Area -->
                        <Grid Grid.Column="1" Grid.RowSpan="3" Margin="24,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 5. CONSOLE AREA -->
                            <Border x:Name="ConsoleArea" Grid.Row="0" CornerRadius="12" BorderThickness="1" BorderBrush="#1A1C26" VerticalAlignment="Stretch">
                                <Border.Background>
                                    <SolidColorBrush Color="#08090C"/>
                                </Border.Background>
                                <Grid>
                                    <!-- Console header -->
                                    <Border CornerRadius="12,12,0,0" Padding="12,8" VerticalAlignment="Top"
                                            BorderThickness="0,0,0,1" BorderBrush="#1A1C26">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0B0C10" Opacity="0.6"/>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Fill="#FF4757" Margin="0,0,6,0"/>
                                            <Ellipse Width="10" Height="10" Fill="#FFA502" Margin="0,0,6,0"/>
                                            <Ellipse Width="10" Height="10" Fill="#2ED573" Margin="0,0,12,0"/>
                                            <TextBlock Text="terminal" FontFamily="Consolas" FontSize="10" Foreground="#2A2D3A"/>
                                        </StackPanel>
                                    </Border>

                                    <ScrollViewer x:Name="ConsoleScroller" Margin="0,32,0,0" 
                                                  VerticalScrollBarVisibility="Auto" Padding="14,8,14,10">
                                        <TextBlock x:Name="TbConsole" 
                                                   FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource Accent}"
                                                   TextWrapping="Wrap" LineHeight="16">
                                            <Run Foreground="#2A2D3A">[system]</Run><Run Text=" Core loaded successfully."/><LineBreak/>
                                            <Run Foreground="#2A2D3A">[system]</Run><Run Text=" Awaiting user input..."/>
                                        </TextBlock>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                <!-- STATUS BADGE -->
                                <Border x:Name="StatusBadge" CornerRadius="8" Padding="12,8" HorizontalAlignment="Left" Margin="0,0,0,8">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="StatusBadgeBg" Color="#0F1014"/>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{DynamicResource Accent}" Margin="0,0,8,0">
                                            <Ellipse.Effect>
                                                <DropShadowEffect x:Name="StatusGlow" Color="{DynamicResource Accent}" BlurRadius="10" ShadowDepth="0"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock x:Name="TbStatusLabel" Text="STATUS: ONLINE" 
                                                   FontFamily="Segoe UI" FontWeight="Bold" FontSize="10" 
                                                   Foreground="#F1F2F6"/>
                                    </StackPanel>
                                </Border>

                                <!-- PROGRESS BAR -->
                                <ProgressBar x:Name="HackProgress" Height="4" Margin="0,0,0,8"
                                             Style="{StaticResource NeonProgress}" Value="0" Maximum="100" Visibility="Collapsed"/>

                                <!-- RESULT PANEL -->
                                <Border x:Name="PanelResult" Height="50"
                                        Visibility="Collapsed" CornerRadius="12" Padding="16,12" BorderThickness="1" BorderBrush="#143D1F">
                                    <Border.Background>
                                        <SolidColorBrush Color="#0A1F10" Opacity="0.8"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="✅" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="ПАРОЛЬ НАЙДЕН" FontFamily="Segoe UI" FontWeight="ExtraBold" 
                                                       FontSize="9" Foreground="#2ED573" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="TxtPassword" Text="••••••••••" FontFamily="Consolas" FontSize="16" Foreground="White" 
                                                       FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- VIEW: SETTINGS -->
                    <Grid x:Name="ViewSettings" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="НАСТРОЙКИ" FontFamily="Segoe UI" FontWeight="Bold" FontSize="20" Foreground="White" Margin="0,0,0,24" HorizontalAlignment="Center"/>
                            
                            <TextBlock Text="ТЕМА ОФОРМЛЕНИЯ" FontFamily="Segoe UI" FontSize="12" Foreground="#57606F" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                                <Button x:Name="BtnThemeCyan" Width="32" Height="32" Margin="0,0,12,0" Background="#00F0FF" Click="BtnTheme_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Ellipse Fill="{TemplateBinding Background}" Stroke="White" StrokeThickness="2"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="BtnThemePink" Width="32" Height="32" Margin="0,0,12,0" Background="#FF007F" Click="BtnTheme_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Ellipse Fill="{TemplateBinding Background}" Stroke="Transparent" StrokeThickness="0"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="BtnThemePurple" Width="32" Height="32" Margin="0,0,12,0" Background="#6C5CE7" Click="BtnTheme_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Ellipse Fill="{TemplateBinding Background}" Stroke="Transparent" StrokeThickness="0"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <!-- VIEW: LOGS -->
                    <Grid x:Name="ViewLogs" Visibility="Collapsed">
                         <TextBlock Text="ЛОГИ ОТСУТСТВУЮТ" FontFamily="Segoe UI" FontSize="14" Foreground="#57606F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
